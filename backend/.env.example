# Core Settings
NODE_ENV=production
PORT=3001

# Database
DATABASE_URL=postgresql://user:password@hostname.render.com/db_name?sslmode=require

# Security (Replace with a secure random string in production)
JWT_SECRET=super_secure_random_jwt_secret_key_2026
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
CORS_ORIGIN=https://harishome.com
FRONTEND_URL=https://harishome.com

# Socket.IO
SOCKET_IO_CORS=https://harishome.com

# Redis (Optional: Leave empty to gracefully disable)
REDIS_URL=

# Cloudinary (Optional: Leave empty to skip initialization)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Firebase (For push notifications and admin functions)
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_STORAGE_BUCKET=

# Typesense (Optional: Leave empty to disable search features)
TYPESENSE_HOST=
TYPESENSE_API_KEY=

# DGateway Payment Config (Optional: Leave empty to use mock mode)
DGATEWAY_MODE=live
DGATEWAY_BASE_URL=
DGATEWAY_API_KEY=
DGATEWAY_MERCHANT_ID=
DGATEWAY_CALLBACK_URL=https://your-api.onrender.com/api/v1/payments/dgateway/webhook
DGATEWAY_RETURN_URL=https://harishome.com/profile
